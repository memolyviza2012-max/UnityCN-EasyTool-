<Window x:Class="UnityCNEasyTool.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        TextElement.Foreground="{DynamicResource MaterialDesignBody}"
        TextElement.FontWeight="Regular"
        TextElement.FontSize="13"
        TextOptions.TextFormattingMode="Ideal"
        TextOptions.TextRenderingMode="Auto"
        Background="{DynamicResource MaterialDesignPaper}"
        FontFamily="{DynamicResource MaterialDesignFont}"
        Title="UnityCN EasyTool" Width="700" SizeToContent="Height"
        ResizeMode="CanMinimize"
        WindowStartupLocation="CenterScreen"
        AllowDrop="True" Drop="Window_Drop" DragOver="Window_DragOver">
    
    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="8"/>
            <RowDefinition MinHeight="160" Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="120"/>
        </Grid.RowDefinitions>

        <!-- Header / Controls -->
        <materialDesign:Card Grid.Row="0" Margin="0,0,0,16" Padding="16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="200"/>
                    </Grid.ColumnDefinitions>

                    <materialDesign:PackIcon Kind="GamepadVariant" VerticalAlignment="Center" Width="24" Height="24" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <ComboBox x:Name="GameComboBox" Grid.Column="1" materialDesign:HintAssist.Hint="Select Game" Margin="0,0,16,0" Style="{StaticResource MaterialDesignFloatingHintComboBox}" SelectionChanged="GameComboBox_SelectionChanged" DisplayMemberPath="Name"/>
                    
                    <materialDesign:PackIcon Kind="KeyVariant" Grid.Column="2" VerticalAlignment="Center" Width="24" Height="24" Margin="0,0,8,0" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBox x:Name="KeyTextBox" Grid.Column="3" materialDesign:HintAssist.Hint="Decryption Key" Style="{StaticResource MaterialDesignFloatingHintTextBox}"/>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,16,0,0">
                    <TextBlock Text="Mode:" VerticalAlignment="Center" Margin="0,0,16,0" FontWeight="Bold"/>
                    <RadioButton x:Name="DecryptRadio" Content="Decrypt" IsChecked="True" Style="{StaticResource MaterialDesignChoiceChipPrimaryRadioButton}" Margin="0,0,8,0"/>
                    <RadioButton x:Name="EncryptRadio" Content="Encrypt" Style="{StaticResource MaterialDesignChoiceChipPrimaryRadioButton}"/>
                </StackPanel>
            </StackPanel>
        </materialDesign:Card>

        <!-- Drag and Drop Zone (Row 1 is an 8px spacer; Row 2 has MinHeight=160 to prevent collapse) -->
        <materialDesign:Card Grid.Row="2" Margin="0,0,0,16" Background="{DynamicResource MaterialDesignDarkSeparatorBackground}">
            <Border BorderBrush="{DynamicResource PrimaryHueMidBrush}" BorderThickness="2" CornerRadius="4" Margin="4" MinHeight="160">
                <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                    <materialDesign:PackIcon Kind="FolderUpload" Width="64" Height="64" HorizontalAlignment="Center" Foreground="{DynamicResource PrimaryHueMidBrush}"/>
                    <TextBlock Text="Drag &amp; Drop Files or Folders Here" FontSize="20" FontWeight="SemiBold" HorizontalAlignment="Center" Margin="0,16,0,8"/>
                    <TextBlock x:Name="SelectedFilesText" Text="Selected: 0 files" Opacity="0.7" HorizontalAlignment="Center"/>
                    <Button Content="Browse..." Margin="0,16,0,0" Click="BrowseButton_Click" Style="{StaticResource MaterialDesignOutlinedButton}"/>
                </StackPanel>
            </Border>
        </materialDesign:Card>

        <!-- Output Options -->
        <materialDesign:Card Grid.Row="3" Margin="0,0,0,16" Padding="16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                
                <StackPanel Orientation="Horizontal" Grid.Column="0">
                    <TextBlock Text="Output:" VerticalAlignment="Center" Margin="0,0,16,0" FontWeight="Bold"/>
                    <RadioButton x:Name="SameFolderRadio" Content="Same Folder" IsChecked="True" Margin="0,0,16,0" VerticalAlignment="Center"/>
                    <RadioButton x:Name="CustomFolderRadio" Content="Custom" VerticalAlignment="Center" Margin="0,0,16,0"/>
                </StackPanel>

                <TextBox x:Name="OutputPathTextBox" Grid.Column="1" materialDesign:HintAssist.Hint="Custom output path..." Style="{StaticResource MaterialDesignFloatingHintTextBox}" IsEnabled="{Binding IsChecked, ElementName=CustomFolderRadio}" VerticalAlignment="Center" Margin="0,0,8,0"/>
                <Button Grid.Column="2" Content="..." Click="BrowseOutput_Click" IsEnabled="{Binding IsChecked, ElementName=CustomFolderRadio}" Style="{StaticResource MaterialDesignRaisedLightButton}" VerticalAlignment="Bottom"/>
            </Grid>
        </materialDesign:Card>

        <!-- Progress and Action -->
        <Grid Grid.Row="4" Margin="0,0,0,16">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" VerticalAlignment="Center" Margin="0,0,16,0">
                <ProgressBar x:Name="WorkProgressBar" Height="8" Minimum="0" Maximum="100" Margin="0,0,0,8" Foreground="{DynamicResource PrimaryHueMidBrush}" Background="{DynamicResource MaterialDesignDivider}"/>
                <TextBlock x:Name="StatusText" Text="Ready" Opacity="0.8" FontSize="12"/>
            </StackPanel>
            <Button x:Name="StartButton" Grid.Column="1" Content="🚀 START ENGINE" Height="48" Width="180" FontSize="16" Style="{StaticResource MaterialDesignRaisedButton}" Click="StartButton_Click"/>
        </Grid>

        <!-- Log Area -->
        <TextBox x:Name="LogTextBox" Grid.Row="5" IsReadOnly="True" TextWrapping="Wrap" VerticalScrollBarVisibility="Auto" Background="#111111" Foreground="#4AF626" FontFamily="Consolas" FontSize="12" Padding="8" materialDesign:HintAssist.Hint="Console Output..." Style="{StaticResource MaterialDesignOutlinedTextBox}"/>
    </Grid>
</Window>
